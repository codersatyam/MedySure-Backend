# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
# New API key format (preferred)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://xxxx.supabase.co/auth/v1/.well-known/jwks.json
# Legacy key format (fallback — use these OR the new keys above)
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_JWT_SECRET=your-jwt-secret

# CORS
CORS_ORIGIN=http://localhost:5173

# Frontend / OAuth
APP_URL=http://localhost:5173
# Where Supabase redirects after email confirmation / OAuth login.
# Defaults to ${APP_URL}/auth/callback if unset.
OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@medysure.com
